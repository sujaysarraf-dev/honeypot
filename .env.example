# ============================================
# Honeypot Platform Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# --------------------------------------------
# Alerting Configuration
# --------------------------------------------
# Telegram Bot (Recommended for mobile alerts)
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Get chat ID by messaging your bot and visiting:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# Slack Webhook (Optional)
# Create incoming webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK=

# Generic Webhook (Optional)
# For custom integrations (Discord, Microsoft Teams, etc.)
WEBHOOK_URL=

# Alert Threshold - Minimum events before alerting
ALERT_THRESHOLD=5

# --------------------------------------------
# Security Configuration
# --------------------------------------------
# Change these in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=honeypot2024

# Session Secret (generate a random string)
SECRET_KEY=your-secret-key-change-in-production

# --------------------------------------------
# Database Configuration (Optional)
# --------------------------------------------
# For persistent storage
DB_HOST=localhost
DB_PORT=5432
DB_NAME=honeypot
DB_USER=honeypot
DB_PASSWORD=change_me

# --------------------------------------------
# Network Configuration
# --------------------------------------------
# Dashboard port
DASHBOARD_PORT=5000

# Honeypot service ports
HTTP_HONEYPOT_PORT=8080
SSH_HONEYPOT_PORT=2222
FTP_HONEYPOT_PORT=2121
SMB_HONEYPOT_PORT=445
DB_HONEYPOT_PORT=3306

# --------------------------------------------
# Feature Flags
# --------------------------------------------
# Enable/disable features
ENABLE_TELEGRAM_ALERTS=true
ENABLE_SLACK_ALERTS=false
ENABLE_WEBHOOK_ALERTS=false
ENABLE_GEOIP=true
ENABLE_PACKET_CAPTURE=true

# --------------------------------------------
# Logging Configuration
# --------------------------------------------
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# --------------------------------------------
# IOC Detection & Tracking
# --------------------------------------------
# Patterns to monitor (comma-separated)
IOC_PATTERNS=sql_injection,command_injection,path_traversal,xss,malicious_commands

# IOC Database path
IOC_DB_PATH=/data/iocs/ioc_database.db

# IOC retention period (days)
IOC_RETENTION_DAYS=90

# Suspicious threshold (attempts before marking suspicious)
SUSPICIOUS_THRESHOLD=10

# Block threshold (attempts before auto-blocking)
BLOCK_THRESHOLD=50

# Auto-block IPs that exceed thresholds (true/false)
AUTO_BLOCK_ENABLED=false

# --------------------------------------------
# Logging Configuration (Advanced)
# --------------------------------------------
# Log format: json or text
LOG_FORMAT=json

# Maximum log file size before rotation (bytes, default 10MB)
LOG_MAX_BYTES=10485760

# Number of backup log files to keep
LOG_BACKUP_COUNT=5

# Log directory
LOG_DIR=/logs

# Data directory
DATA_DIR=/data

# Archive directory for rotated logs
ARCHIVE_DIR=/data/archives

# --------------------------------------------
# Security & Attack Protection
# --------------------------------------------
# DDoS protection threshold (requests per minute)
DDOS_THRESHOLD=100

# DDoS time window (seconds)
DDOS_WINDOW=60

# API rate limit (requests per minute)
API_RATE_LIMIT=60

# Block duration for attacks (minutes)
BLOCK_DURATION_MINUTES=60

# --------------------------------------------
# Automated Cleanup
# --------------------------------------------
# Enable automatic cleanup (true/false)
ENABLE_AUTO_CLEANUP=true

# Cleanup schedule (24-hour format, e.g., "02:00" for 2 AM)
CLEANUP_SCHEDULE=02:00

# Archive retention period (days)
ARCHIVE_RETENTION_DAYS=30

