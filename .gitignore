# ============================================
# Honeypot Platform - Clean Git Ignore
# ============================================

# 🔴 Environment variables (CRITICAL)
.env
.env.*
!.env.example

# 🔴 Runtime data (DO NOT COMMIT)
data/
logs/
captures/
sessions/
iocs/

# Packet captures & logs
*.log
*.pcap
*.pcapng

# Python
__pycache__/
**/__pycache__/
*.pyc
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/

# Build / distribution
build/
dist/
*.egg-info/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# IDE / editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db

# Docker
.dockerignore

# Temporary files
*.tmp
*.bak
*.backup
