# ============================================
# Honeypot Platform - Git Ignore
# ============================================

# Environment variables
.env
.env.local
.env.*.local

# Data and logs
data/*
!data/.gitkeep
*.log
*.pcap
*.pcapng
*.json
captures/
sessions/
iocs/

# Python
__pycache__/
**/__pycache__/
*.pyc
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/

# Docker
.dockerignore

# Obsidian (if used for docs)
.obsidian/

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# OS files
Thumbs.db
.DS_Store
*.lnk

